theme_override_colors/default_color = Color(0.0056611504, 0.0056611514, 0.00566115, 1)
theme_override_font_sizes/normal_font_size = 11
text = "Years ago, gnomes and cats were mortal enemies. Cats would attack gnome villages and play with them like toys. This is what started the great Cat and Gnome War of 999 BGE. After many years of fighting, the council of cat elders met with the newly instated gnome queen, Freyga, and formed a truce. For centuries, gnomes and cats lived in harmony and many became friends."
fit_content = true

